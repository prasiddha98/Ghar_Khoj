# Root environment example for Ghar Khoj
# Copy this file to .env and fill in real values before starting the app.

# API / database
PORT=3000
DATABASE_URL=postgresql://rental_db_vt09_user:cm8ySG69gsEiuIysZUvBnXntIqPb2IS3@dpg-d87g4gt7vvec7391acf0-a.oregon-postgres.render.com/rental_db_vt09
JWT_SECRET=replace_with_a_secure_random_value
PRIVATE_OBJECT_DIR=ghar-khoj-private
PUBLIC_OBJECT_SEARCH_PATHS=ghar-khoj-public
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_DIR=./local-storage

# JWT / auth
JWT_ALG=HS256
JWT_TTL_SECONDS=86400

# Logging and environment
LOG_LEVEL=info
NODE_ENV=development

# Frontend origin (used for CORS in production)
# Set this to the public URL of your deployed frontend (e.g. https://your-app.onrender.com)
FRONTEND_ORIGIN=http://localhost:5173

# Khalti configuration (server-side secret must NOT be exposed to frontend)
KHALTI_SECRET_KEY=your_khalti_secret_key_here
KHALTI_ENV=development
KHALTI_WEB_BASE_URL=http://localhost:5173

# Frontend public key (safe to expose)
VITE_KHALTI_PUBLIC_KEY=your_khalti_public_key_here

# Frontend and API
VITE_API_URL=https://rental-api-xqc6.onrender.com
BASE_PATH=/
API_PROXY_TARGET=http://api:3000
WEB_PORT=5173

# Additional environment variables
# Add provider credentials and feature flags below
