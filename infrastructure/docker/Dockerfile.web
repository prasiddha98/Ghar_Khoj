FROM node:22-slim

WORKDIR /repo

# Copy repository
COPY . /repo

# Install pnpm v8 globally and run workspace install
RUN npm install -g pnpm@8 --force
RUN pnpm install

ENV PORT=5173
ENV BASE_PATH=/

EXPOSE 5173

# Start the frontend dev server bound to 0.0.0.0
CMD ["sh","-c","PORT=${PORT} BASE_PATH=${BASE_PATH} pnpm --filter @workspace/ghar-khoj run dev -- --host 0.0.0.0 --port ${PORT}"]
